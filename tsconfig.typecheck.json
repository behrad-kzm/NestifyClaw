{
  "extends": "./tsconfig.json",
  "comment": "Type-checks nestify-owned framework code only. Vendored openclaw extensions under src/connectors/<channel>/extension/ are intentionally excluded.",
  "include": [
    "src/main.ts",
    "src/app.module.ts",
    "src/common/**/*.ts",
    "src/core/host/**/*.ts",
    "src/core/core.module.ts",
    "src/gateway/**/*.ts",
    "src/connectors/connectors.module.ts",
    "src/connectors/*/host/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "src/connectors/**/extension/**",
    "src/core/openclaw/**"
  ]
}
