{
  "$schema": "https://swc.rs/schema.json",
  "exclude": [
    ".*\\.spec\\.ts$",
    ".*\\.test\\.ts$",
    ".*test-utils\\.ts$",
    ".*test-shared\\.ts$",
    ".*e2e-harness\\.ts$",
    "src/connectors/telegram/extension/index\\.ts$",
    "src/connectors/telegram/extension/setup-entry\\.ts$",
    "src/connectors/telegram/extension/src/telegram-ingress-worker\\.ts$",
    "src/connectors/whatsapp/extension/index\\.ts$",
    "src/connectors/whatsapp/extension/setup-entry\\.ts$"
  ],
  "jsc": {
    "target": "es2022",
    "baseUrl": ".",
    "paths": {
      "openclaw/plugin-sdk/*": ["./src/common/openclaw/plugin-sdk/*"],
      "openclaw/*": ["./src/common/openclaw/*"]
    },
    "parser": {
      "syntax": "typescript",
      "decorators": true,
      "dynamicImport": true
    },
    "transform": {
      "legacyDecorator": true,
      "decoratorMetadata": true
    },
    "keepClassNames": true
  },
  "module": {
    "type": "commonjs"
  }
}
