# Telegram bot token from @BotFather (https://t.me/BotFather).
# Copy this file to .env and fill in the value.
TELEGRAM_BOT_TOKEN=

# HTTP port for the NestJS app (optional, defaults to 3000).
PORT=3000

# Remote Ollama base URL (native API — no /v1 suffix).
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_API_KEY=ollama-local

# Primary model ref (ollama/ prefix optional).
OLLAMA_PRIMARY_MODEL=qwen3.5:9b

# Full model catalog on your Ollama server (comma-separated).
OLLAMA_MODELS=qwen3.5:27b,deepseek-r1:8b,qwen3.5:9b,gemma4:26b,gemma4:31b,gemma4:e4b

# Fallback chain when primary fails (comma-separated model ids).
OLLAMA_FALLBACK_MODELS=deepseek-r1:8b,qwen3.5:9b

OLLAMA_TIMEOUT_SECONDS=300
OLLAMA_NUM_CTX=32768
OLLAMA_HISTORY_LIMIT=40

# Extra HTTP headers as JSON (ngrok free tier often needs this).
OLLAMA_EXTRA_HEADERS={"ngrok-skip-browser-warning":"true"}

# Agent identity and workspace (OpenClaw-shaped paths).
AGENT_ID=main
NESTIFY_STATE_DIR=~/.nestify-claw
NESTIFY_WORKSPACE_DIR=~/.nestify-claw/workspace

# Optional system prompt prepended to every turn.
# AGENT_SYSTEM_PROMPT=You are a helpful assistant.

# --- Session routing (OpenClaw session.dmScope) ---

# DM session isolation. Default: main (all DMs share one bucket).
# Use per-channel-peer for multi-user bots (recommended).
# SESSION_DM_SCOPE=main
# SESSION_DM_SCOPE=per-peer
SESSION_DM_SCOPE=per-channel-peer
# SESSION_DM_SCOPE=per-account-channel-peer

# Main DM bucket name when SESSION_DM_SCOPE=main (default: main).
# SESSION_MAIN_KEY=main

# Link the same person across channels (OpenClaw session.identityLinks), JSON object.
# SESSION_IDENTITY_LINKS={"alice":["telegram:123","whatsapp:+15551230001"]}
