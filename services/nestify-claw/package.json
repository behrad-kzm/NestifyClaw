{
  "name": "nestify-claw",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "npm run typecheck && tsx scripts/build.ts",
    "build:nest": "nest build -b swc",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "gen:adapter": "tsx scripts/generate-extension-adapter.ts",
    "start": "tsx src/main.ts",
    "start:dev": "tsx watch src/main.ts",
    "start:debug": "tsx watch src/main.ts",
    "start:prod": "node dist/main.mjs",
    "start:prod:nest": "node dist/main.js",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest --config test/jest-unit.json",
    "test:watch": "jest --config test/jest-unit.json --watch",
    "test:cov": "jest --config test/jest-unit.json --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@grammyjs/runner": "2.0.3",
    "@grammyjs/transformer-throttler": "1.2.1",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "audio-decode": "^2.2.3",
    "baileys": "^7.0.0-rc13",
    "grammy": "1.43.0",
    "qrcode-terminal": "^0.12.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.1",
    "typebox": "1.1.39",
    "undici": "8.3.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@swc/cli": "^0.5.2",
    "@swc/core": "^1.15.40",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.2",
    "@types/node": "^20.3.1",
    "@types/qrcode-terminal": "^0.12.2",
    "@types/supertest": "^6.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "esbuild": "^0.24.2",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "jest": "^29.5.0",
    "prettier": "^3.0.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.19.2",
    "typescript": "^5.1.3"
  },
  "jest": {
    "projects": [
      "<rootDir>/test/jest-unit.json",
      "<rootDir>/test/jest-e2e.json"
    ]
  }
}
